<mxfile host="app.diagrams.net" version="21.0">
  <diagram name="订单超时处理时序图" id="order-seq">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== 参与者头部 ===== -->
        <mxCell id="h1" value="TradeOrderService" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="20" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="MySQL" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="340" y="20" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="RocketMQ" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="560" y="20" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h4" value="OrderTimeoutListener" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="800" y="20" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- ===== 生命线 ===== -->
        <mxCell id="l1" style="endArrow=none;dashed=1;html=1;strokeWidth=1;strokeColor=#6c8ebf;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="60" as="sourcePoint" />
            <mxPoint x="140" y="830" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="l2" style="endArrow=none;dashed=1;html=1;strokeWidth=1;strokeColor=#82b366;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="390" y="60" as="sourcePoint" />
            <mxPoint x="390" y="830" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="l3" style="endArrow=none;dashed=1;html=1;strokeWidth=1;strokeColor=#d6b656;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="620" y="60" as="sourcePoint" />
            <mxPoint x="620" y="830" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="l4" style="endArrow=none;dashed=1;html=1;strokeWidth=1;strokeColor=#9673a6;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="890" y="60" as="sourcePoint" />
            <mxPoint x="890" y="830" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== 消息 ===== -->

        <!-- 1. 获取锁 -->
        <mxCell id="m1" value="1. RLock.tryLock(3, 10s)" style="html=1;align=left;verticalAlign=bottom;endArrow=block;endFill=1;curved=0;rounded=0;fontSize=11;exitX=0;exitY=0;exitDx=0;exitDy=0;" edge="1" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint x="140" y="100" as="sourcePoint" />
            <mxPoint x="140" y="140" as="targetPoint" />
            <Array as="points">
              <mxPoint x="100" y="120" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 2. 创建订单 -->
        <mxCell id="m2" value="2. 创建订单(status=0)，更新商品(status=2)" style="html=1;align=left;verticalAlign=bottom;endArrow=block;endFill=1;curved=0;rounded=0;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="160" as="sourcePoint" />
            <mxPoint x="390" y="160" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 3. 发送延时消息 -->
        <mxCell id="m3" value="3. 发送延时消息 (level16 ≈ 30min)" style="html=1;align=left;verticalAlign=bottom;endArrow=block;endFill=1;curved=0;rounded=0;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="210" as="sourcePoint" />
            <mxPoint x="620" y="210" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 4. 释放锁 -->
        <mxCell id="m4" value="4. 释放锁" style="html=1;align=left;verticalAlign=bottom;endArrow=block;endFill=1;curved=0;rounded=0;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="260" as="sourcePoint" />
            <mxPoint x="140" y="300" as="targetPoint" />
            <Array as="points">
              <mxPoint x="100" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== 分隔 ===== -->
        <mxCell id="sep" style="endArrow=none;dashed=1;html=1;strokeWidth=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="40" y="330" as="sourcePoint" />
            <mxPoint x="1020" y="330" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== alt: 支付成功 ===== -->
        <mxCell id="alt1" value="alt [支付成功]" style="shape=mxgraph.basic.rect;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;align=left;verticalAlign=top;whiteSpace=wrap;html=1;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="50" y="340" width="960" height="90" as="geometry" />
        </mxCell>

        <!-- 5. 支付回调 -->
        <mxCell id="m5" value="5. /pay/notify 验签，订单→status=1，payment_status=1" style="html=1;align=left;verticalAlign=bottom;endArrow=block;endFill=1;curved=0;rounded=0;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="385" as="sourcePoint" />
            <mxPoint x="390" y="385" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== else: 超时未支付 ===== -->
        <mxCell id="alt2" value="else [超时30min未支付]" style="shape=mxgraph.basic.rect;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;align=left;verticalAlign=top;whiteSpace=wrap;html=1;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="50" y="440" width="960" height="370" as="geometry" />
        </mxCell>

        <!-- 6. 投递延时消息 -->
        <mxCell id="m6" value="6. 投递延时消息" style="html=1;align=left;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="620" y="490" as="sourcePoint" />
            <mxPoint x="890" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 7. 查询订单状态 -->
        <mxCell id="m7" value="7. 查询订单状态" style="html=1;align=left;verticalAlign=bottom;endArrow=block;endFill=1;curved=0;rounded=0;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="890" y="550" as="sourcePoint" />
            <mxPoint x="390" y="550" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 8a. 未支付 → 取消 -->
        <mxCell id="m8a" value="8a. status=0 且未支付 → cancelOrder" style="html=1;align=left;verticalAlign=bottom;endArrow=block;endFill=1;curved=0;rounded=0;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="890" y="620" as="sourcePoint" />
            <mxPoint x="390" y="620" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 8a注释 -->
        <mxCell id="n8a" value="订单→status=3 已取消&#xa;商品→status=1 回滚在售" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="400" y="630" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- 8b. 已支付 → 幂等跳过 -->
        <mxCell id="m8b" value="8b. 已支付 → 幂等跳过" style="html=1;align=left;verticalAlign=bottom;endArrow=block;endFill=1;dashed=1;curved=0;rounded=0;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="890" y="720" as="sourcePoint" />
            <mxPoint x="890" y="760" as="targetPoint" />
            <Array as="points">
              <mxPoint x="960" y="740" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
